#===============================================================================
# SXT Validator Dashboard - Configuration
# Copy this file to .env and fill in your values
#   cp .env.example .env
#===============================================================================

# Node connection — RPC and metrics endpoints of your SXT validator
SXT_RPC_URL=
SXT_PROMETHEUS_TARGET=
NODE_EXPORTER_TARGET=

# Your validator name (as set in --name flag)
SXT_VALIDATOR_NAME=

# Exporter settings
SXT_EXPORTER_POLL_INTERVAL=12
SXT_EXPORTER_PORT=9101
SXT_EXPORTER_LOG_LEVEL=INFO
SXT_STAKING_POLL_INTERVAL=120

# Token price polling (CoinGecko, seconds)
SXT_PRICE_POLL_INTERVAL=300

# Prometheus
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_RETENTION=30d
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# Disk mountpoint where SXT chain data is stored (check with df -h)
SXT_DATA_MOUNTPOINT=
